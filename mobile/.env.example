# URL da API Laravel vista pelo telemóvel (Expo Go / build).
#
# Produção (hospedada):
# EXPO_PUBLIC_API_URL=https://economia-api.onrender.com/api
#
# Local — NÃO uses localhost no telemóvel físico (localhost é o próprio telemóvel).
# Substitui pelo IPv4 do teu PC (ipconfig → IPv4) na mesma Wi‑Fi:
# EXPO_PUBLIC_API_URL=http://192.168.1.XX:8000/api
#
# Emulador Android / Expo Web no PC:
# EXPO_PUBLIC_API_URL=http://localhost:8000/api
