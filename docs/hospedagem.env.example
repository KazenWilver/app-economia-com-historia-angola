# Copia para produção (Render / Vercel). NÃO commits valores reais.

# --- Backend (Render) ---
APP_NAME="Economia com História – Angola"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://economia-api.onrender.com
FRONTEND_URL=https://economia-com-historia-snowy.vercel.app

DB_CONNECTION=pgsql
DB_HOST=aws-0-eu-west-1.pooler.supabase.com
DB_PORT=5432
DB_DATABASE=postgres
DB_USERNAME=jindungo_app.PROJECT_REF
DB_PASSWORD=
DB_SSLMODE=require

CACHE_STORE=file
SESSION_DRIVER=array
QUEUE_CONNECTION=sync
LOG_CHANNEL=stderr
FILESYSTEM_DISK=local

LLM_PROVIDER=groq
GROQ_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

SANCTUM_STATEFUL_DOMAINS=economia-com-historia-snowy.vercel.app
CORS_ALLOWED_ORIGINS=https://economia-com-historia-snowy.vercel.app

